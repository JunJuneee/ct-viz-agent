# ───────────────────────────────────────────────────────────────────────────
# Initial setup: copy this file to `.env`, set OPENAI_API_KEY, done.
#   - The app runs with just that (no key → deterministic fallback parser).
#   - Everything under "Optional" is OFF by default — uncomment a block to enable.
# See docs/observability.md for the observability/eval options.
# ───────────────────────────────────────────────────────────────────────────

# ── Core ───────────────────────────────────────────────────────────────────

# OpenAI API key for natural-language interpretation. Blank → fallback parser.
OPENAI_API_KEY=

# Model for interpretation. Must support JSON-schema structured outputs.
OPENAI_MODEL=gpt-4o-mini

# HTTP port for the Express server.
PORT=3000

# Cap on trial records fetched per request.
#   0 = unlimited (default): paginate ALL matches — no truncation, exact counts.
#   N > 0: stop after N records (bounds latency/cost).
MAX_STUDIES=0

# Citations attached to each visualized datum.
MAX_CITATIONS_PER_DATUM=3

# ── Optional: observability & evaluation (all OFF by default) ───────────────
# None of these are required to run. Enable only what you need.

# (1) Langfuse — live tracing + token/cost + online-eval scores.
#     Both keys blank → DRY-RUN: nothing sent; eval scores logged to the console.
#     Fill both to enable. Bundled local server: `npm run langfuse:up` (http://localhost:3001).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_BASEURL=http://localhost:3001   # self-host URL; omit for Langfuse Cloud

# (2) LLM-as-judge — samples traffic; a stronger model scores whether the
#     visualization answers the question (judge_appropriate / judge_confidence).
#     OFF by default; needs OPENAI_API_KEY. Uncomment to opt in.
# JUDGE_SAMPLE_RATE=0.2        # 0 = off (default), 1 = every request, 0.2 = 20%
# JUDGE_MODEL=gpt-4.1          # stronger than the interpret model (gpt-4o-mini)

# (3) OpenTelemetry — app/infra tracing (HTTP + outbound calls + stage spans).
#     OFF by default. No endpoint → console spans; with endpoint → OTLP (`npm run otel:up`).
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=ct-viz-agent
